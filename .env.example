# ===========================================
# SJB Property — Lead Gen Pipeline API Keys
# ===========================================
# Copy this file to .env and fill in your keys
# NEVER commit .env to git (it's in .gitignore)

# EPC Open Data API (Domestic Energy Performance Certificates)
# Get from: https://epc.opendatacommunities.org/docs/api
EPC_API_EMAIL=
EPC_API_KEY=
EPC_AUTH_TOKEN=

# Companies House API
# Get from: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# Notion API (CRM — Lead Pipeline)
# Create integration at: https://www.notion.so/profile/integrations
NOTION_API_KEY=
# Database ID from URL: notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=
